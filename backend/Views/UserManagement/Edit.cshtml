@model backend.Controllers.EditUserViewModel

@{
    ViewData["Title"] = "Chỉnh sửa Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Chỉnh sửa Người dùng</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Tên</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label">Trạng thái</label>
                <select asp-for="Status" class="form-select">
                    <option value="Active">Hoạt động</option>
                    <option value="Inactive">Không hoạt động</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SelectedRole" class="form-label">Vai trò</label>
                <select asp-for="SelectedRole" class="form-select" id="roleSelect">
                    @if (ViewBag.Roles != null)
                    {
                        foreach (var role in ViewBag.Roles)
                        {
                            <option value="@role.Name">@role.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="SelectedRole" class="text-danger"></span>
            </div>
            <div class="mb-3" id="driverFields" style="display: none;">
                <label asp-for="LicenseNumber" class="form-label">Số bằng lái</label>
                <input asp-for="LicenseNumber" class="form-control" />
                <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                <label asp-for="LicenseType" class="form-label">Loại bằng lái</label>
                <input asp-for="LicenseType" class="form-control" />
                <span asp-validation-for="LicenseType" class="text-danger"></span>
            </div>
            <div class="mb-3" id="managerFields" style="display: none;">
                <label asp-for="AccessRights" class="form-label">Quyền truy cập</label>
                <input asp-for="AccessRights" class="form-control" />
                <span asp-validation-for="AccessRights" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleFields() {
            const role = document.getElementById('roleSelect').value;
            const driverFields = document.getElementById('driverFields');
            const managerFields = document.getElementById('managerFields');

            driverFields.style.display = role === 'Driver' ? 'block' : 'none';
            managerFields.style.display = role === 'Manager' ? 'block' : 'none';
        }

        document.getElementById('roleSelect').addEventListener('change', toggleFields);
        // Initial check
        toggleFields();
    </script>
}