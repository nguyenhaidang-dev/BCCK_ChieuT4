@model backend.Models.User

@{
    ViewData["Title"] = "Xóa Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Xóa Người dùng</h1>
</div>

<h3>Bạn có chắc chắn muốn xóa người dùng này?</h3>
<div>
    <h4>Người dùng</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Tên:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>

        <dt class="col-sm-2">Email:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Email)</dd>

        <dt class="col-sm-2">Vai trò:</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Role)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>