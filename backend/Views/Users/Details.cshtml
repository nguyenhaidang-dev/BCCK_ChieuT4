@model backend.Models.User

@{
    ViewData["Title"] = "Chi tiết Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Chi tiết Người dùng</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Chỉnh sửa</a>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Tên:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="col-sm-4">Email:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Email)</dd>

            <dt class="col-sm-4">Số điện thoại:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Phone)</dd>

            <dt class="col-sm-4">Vai trò:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Role)</dd>

            <dt class="col-sm-4">Trạng thái:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.Status)</dd>

            <dt class="col-sm-4">Ngày tạo:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.CreatedAt)</dd>

            <dt class="col-sm-4">Ngày cập nhật:</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.UpdatedAt)</dd>

            @if (Model.Role == backend.Models.Role.Driver)
            {
                <dt class="col-sm-4">Số bằng lái:</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.LicenseNumber)</dd>

                <dt class="col-sm-4">Loại bằng lái:</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.LicenseType)</dd>
            }
        </dl>
    </div>
</div>