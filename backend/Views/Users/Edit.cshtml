@model backend.Models.User

@{
    ViewData["Title"] = "Chỉnh sửa Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Chỉnh sửa Người dùng</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PasswordHash" />
            <input type="hidden" asp-for="CreatedAt" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" type="email" class="form-control" readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Role" class="form-label"></label>
                <select asp-for="Role" class="form-select">
                    <option value="Driver">Tài xế</option>
                    <option value="Manager">Quản lý</option>
                    <option value="Admin">Quản trị viên</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select">
                    <option value="Active">Hoạt động</option>
                    <option value="Inactive">Không hoạt động</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="mb-3" id="driverFields" style="@(Model.Role != backend.Models.Role.Driver ? "display: none;" : "")">
                <label asp-for="LicenseNumber" class="form-label"></label>
                <input asp-for="LicenseNumber" class="form-control" />
                <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                <label asp-for="LicenseType" class="form-label"></label>
                <input asp-for="LicenseType" class="form-control" />
                <span asp-validation-for="LicenseType" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <input type="submit" value="Lưu" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('Role').addEventListener('change', function() {
            const driverFields = document.getElementById('driverFields');
            driverFields.style.display = this.value === 'Driver' ? 'block' : 'none';
        });
    </script>
}